APP_ENV=test
SECRET_KEY=default-api-fast-secret
DB_NAME=default_api_fast
DB_USERNAME=developer
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
# Optional override if you want a full URI instead of components.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/default_api_fast_development

# Storage (local or s3)
STORAGE_SERVICE=local
STORAGE_LOCAL_ROOT=storage
STORAGE_LOCAL_PUBLIC_ENDPOINT=/api/files
STORAGE_MAX_CONTENT_LENGTH_MB=100

# S3 (only when STORAGE_SERVICE=s3)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_PREFIX=
STORAGE_S3_PUBLIC_URL=
STORAGE_S3_PRESIGNED_EXPIRES_IN=3600
STORAGE_S3_ACL=
